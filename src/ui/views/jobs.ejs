<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Dashboard - Job Tracker</title>
</head>
<body>
  <div class="cy-app">
    <%- include('partials/sidebar', { activePage: 'dashboard' }) %>

    <main class="cy-main">
      <div class="cy-page">

        <!-- Page Header -->
        <div class="cy-page-header">
          <h1>Dashboard</h1>
          <span class="cy-page-header-meta"><%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
        </div>

        <!-- ============================================================
             STAT CARDS with SVG Sparklines (CyFocus style)
             ============================================================ -->
        <%
          var totalJobs = stats.totalJobs || 0;
          var newCount = stats.statusCounts.new || 0;
          var appliedCount = stats.statusCounts.applied || 0;
          var reviewedCount = stats.statusCounts.reviewed || 0;
          var urgentCount = stats.priorityCounts.urgent || 0;
          var highCount = stats.priorityCounts.high || 0;
          var pendingEnrich = stats.pendingEnrichment || 0;
        %>
        <div class="cy-stats-row">

          <!-- Total Jobs -->
          <div class="cy-stat-card">
            <div class="cy-stat-info">
              <span class="cy-stat-label">Total Jobs</span>
              <span class="cy-stat-value accent"><%= totalJobs %></span>
              <span class="cy-stat-compare">
                <%= newCount %> new
                <span class="cy-stat-badge up">
                  <svg width="8" height="8" viewBox="0 0 8 8"><path d="M4 1L7 5H1L4 1Z" fill="currentColor"/></svg>
                  active
                </span>
              </span>
            </div>
            <div class="cy-stat-chart">
              <!-- Bar chart sparkline -->
              <svg width="64" height="48" viewBox="0 0 64 48">
                <rect x="2" y="28" width="6" height="20" rx="1" fill="rgba(245,158,11,0.2)"/>
                <rect x="11" y="18" width="6" height="30" rx="1" fill="rgba(245,158,11,0.3)"/>
                <rect x="20" y="24" width="6" height="24" rx="1" fill="rgba(245,158,11,0.25)"/>
                <rect x="29" y="12" width="6" height="36" rx="1" fill="rgba(245,158,11,0.35)"/>
                <rect x="38" y="20" width="6" height="28" rx="1" fill="rgba(245,158,11,0.3)"/>
                <rect x="47" y="8" width="6" height="40" rx="1" fill="rgba(245,158,11,0.4)"/>
                <rect x="56" y="4" width="6" height="44" rx="1" fill="var(--accent)"/>
              </svg>
            </div>
          </div>

          <!-- New Today -->
          <div class="cy-stat-card">
            <div class="cy-stat-info">
              <span class="cy-stat-label">New</span>
              <span class="cy-stat-value"><%= newCount %></span>
              <span class="cy-stat-compare">
                <%= urgentCount %> urgent
                <% if (urgentCount > 0) { %>
                  <span class="cy-stat-badge up">
                    <svg width="8" height="8" viewBox="0 0 8 8"><path d="M4 1L7 5H1L4 1Z" fill="currentColor"/></svg>
                    hot
                  </span>
                <% } else { %>
                  <span class="cy-stat-badge neutral">--</span>
                <% } %>
              </span>
            </div>
            <div class="cy-stat-chart">
              <!-- Trend line sparkline -->
              <svg width="64" height="48" viewBox="0 0 64 48">
                <polyline points="4,38 14,30 24,34 34,22 44,26 54,14 62,8" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="4,38 14,30 24,34 34,22 44,26 54,14 62,8" fill="none" stroke="var(--accent)" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" opacity="0.08"/>
              </svg>
            </div>
          </div>

          <!-- Applied -->
          <div class="cy-stat-card">
            <div class="cy-stat-info">
              <span class="cy-stat-label">Applied</span>
              <span class="cy-stat-value green"><%= appliedCount %></span>
              <span class="cy-stat-compare">
                <%= reviewedCount %> reviewed
                <span class="cy-stat-badge neutral">
                  <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="2" fill="currentColor"/></svg>
                  total
                </span>
              </span>
            </div>
            <div class="cy-stat-chart">
              <!-- Progress arc sparkline -->
              <svg width="48" height="48" viewBox="0 0 48 48">
                <circle cx="24" cy="24" r="18" fill="none" stroke="rgba(34,197,94,0.12)" stroke-width="4"/>
                <circle cx="24" cy="24" r="18" fill="none" stroke="var(--green)" stroke-width="4" stroke-linecap="round"
                  stroke-dasharray="<%= totalJobs > 0 ? Math.round((appliedCount / totalJobs) * 113) : 0 %> 113"
                  transform="rotate(-90 24 24)"/>
                <text x="24" y="27" text-anchor="middle" fill="var(--green-text)" font-size="11" font-weight="700"><%= totalJobs > 0 ? Math.round((appliedCount / totalJobs) * 100) : 0 %>%</text>
              </svg>
            </div>
          </div>

          <!-- Scraper Status -->
          <div class="cy-stat-card">
            <div class="cy-stat-info">
              <span class="cy-stat-label">Scraper</span>
              <span class="cy-stat-value blue" id="dash-scraper-status"><%= agentStatus.running ? 'ON' : 'OFF' %></span>
              <span class="cy-stat-compare">
                Queue: <%= pendingEnrich %>
                <span class="cy-stat-badge neutral">enrichment</span>
              </span>
            </div>
            <div class="cy-stat-chart">
              <!-- Activity bars sparkline -->
              <svg width="64" height="48" viewBox="0 0 64 48">
                <rect x="4" y="16" width="4" height="16" rx="1" fill="<%= agentStatus.running ? 'rgba(59,130,246,0.4)' : 'rgba(255,255,255,0.06)' %>"/>
                <rect x="12" y="10" width="4" height="28" rx="1" fill="<%= agentStatus.running ? 'rgba(59,130,246,0.5)' : 'rgba(255,255,255,0.06)' %>"/>
                <rect x="20" y="18" width="4" height="12" rx="1" fill="<%= agentStatus.running ? 'rgba(59,130,246,0.35)' : 'rgba(255,255,255,0.06)' %>"/>
                <rect x="28" y="6" width="4" height="36" rx="1" fill="<%= agentStatus.running ? 'rgba(59,130,246,0.6)' : 'rgba(255,255,255,0.06)' %>"/>
                <rect x="36" y="14" width="4" height="20" rx="1" fill="<%= agentStatus.running ? 'rgba(59,130,246,0.4)' : 'rgba(255,255,255,0.06)' %>"/>
                <rect x="44" y="8" width="4" height="32" rx="1" fill="<%= agentStatus.running ? 'rgba(59,130,246,0.55)' : 'rgba(255,255,255,0.06)' %>"/>
                <rect x="52" y="4" width="4" height="40" rx="1" fill="<%= agentStatus.running ? 'var(--blue)' : 'rgba(255,255,255,0.08)' %>"/>
              </svg>
            </div>
          </div>

        </div>

        <!-- ============================================================
             TWO COLUMN DASHBOARD GRID
             ============================================================ -->
        <div class="cy-dash-grid">

          <!-- LEFT: Recent Jobs Table -->
          <div class="cy-panel">
            <div class="cy-panel-header">
              <span class="cy-panel-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                Recent Jobs
              </span>
              <a href="/jobs" class="cy-btn cy-btn-sm cy-btn-accent">View All</a>
            </div>
            <div class="cy-panel-flush">
              <% if (jobs.length === 0) { %>
                <div class="cy-empty" style="padding: 40px 20px;">
                  <p>No jobs found yet. Start the scraper agent to begin tracking.</p>
                </div>
              <% } else { %>
                <table class="cy-quick-table">
                  <% jobs.slice(0, 12).forEach(function(job) { %>
                    <tr>
                      <td style="width: 40px;">
                        <span class="cy-score <%= job.matchScore >= 85 ? 'excellent' : job.matchScore >= 70 ? 'good' : job.matchScore >= 50 ? 'decent' : job.matchScore > 0 ? 'low' : 'none' %>">
                          <%= job.matchScore %>
                        </span>
                      </td>
                      <td>
                        <% if (job.priority) { %>
                          <span class="cy-priority <%= job.priority %>"><%= job.priority.toUpperCase() %></span>
                        <% } %>
                        <a href="<%= job.link %>" target="_blank" rel="noopener noreferrer" class="job-link"><%= job.title %></a>
                        <div class="job-company"><%= job.company %><% if (job.location) { %> &middot; <%= job.location %><% } %></div>
                      </td>
                      <td style="width: 80px; text-align: right;">
                        <span class="cy-status <%= job.status %>"><%= job.status %></span>
                      </td>
                    </tr>
                  <% }); %>
                </table>
              <% } %>
            </div>
          </div>

          <!-- RIGHT: Activity Feed (CyFocus "Recent activity" style) -->
          <div class="cy-panel">
            <div class="cy-panel-header">
              <span class="cy-panel-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                Recent Activity
              </span>
            </div>
            <div class="cy-panel-flush">
              <div class="cy-activity-feed">
                <% if (jobs.length === 0) { %>
                  <div class="cy-empty" style="padding: 40px 20px;">
                    <p>No activity yet.</p>
                  </div>
                <% } else { %>
                  <% jobs.slice(0, 25).forEach(function(job) { %>
                    <div class="cy-activity-item">
                      <!-- Round status icon -->
                      <div class="cy-activity-icon <%= job.status %>">
                        <% if (job.status === 'new') { %>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        <% } else if (job.status === 'applied') { %>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        <% } else if (job.status === 'reviewed') { %>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="1"/><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/></svg>
                        <% } else { %>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        <% } %>
                      </div>
                      <!-- Body -->
                      <div class="cy-activity-body">
                        <div class="cy-activity-title">
                          <a href="<%= job.link %>" target="_blank" rel="noopener noreferrer"><%= job.title %></a>
                        </div>
                        <div class="cy-activity-sub"><%= job.company %><% if (job.location) { %> &middot; <%= job.location %><% } %></div>
                      </div>
                      <!-- Timestamp -->
                      <span class="cy-activity-time"><%= job.postedDate %></span>
                      <!-- Arrow -->
                      <span class="cy-activity-arrow">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                      </span>
                    </div>
                  <% }); %>
                <% } %>
              </div>
            </div>
          </div>

        </div>

      </div>
    </main>
  </div>

  <script>
    // Auto-refresh scraper status indicator on dashboard
    (function() {
      async function refresh() {
        try {
          var res = await fetch('/agent/status');
          if (!res.ok) return;
          var s = await res.json();
          var el = document.getElementById('dash-scraper-status');
          if (el) el.textContent = s.running ? 'ON' : 'OFF';
        } catch (e) {}
      }
      setInterval(refresh, 5000);
    })();
  </script>
</body>
</html>
