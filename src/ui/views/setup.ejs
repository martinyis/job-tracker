<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Settings - Job Tracker</title>
</head>
<body>
  <div class="cy-app">
    <%- include('partials/sidebar', { activePage: 'settings' }) %>

    <main class="cy-main">
      <div class="cy-page">

        <!-- Breadcrumb -->
        <div class="cy-breadcrumb">
          <a href="/">Home</a>
          <span class="cy-breadcrumb-sep">></span>
          <span style="color: var(--text-secondary);">Settings</span>
        </div>

        <!-- Page Header -->
        <div class="cy-page-header">
          <h1>Settings</h1>
        </div>

        <% if (saved) { %>
          <div class="cy-toast">Settings saved successfully.</div>
        <% } %>

        <!-- Step indicators -->
        <div class="cy-steps">
          <div class="cy-step <%= apiKey && apiKey !== 'nvapi-...' ? 'done' : '' %>">
            <span class="cy-step-num">1</span>
            <span class="cy-step-label">API Key & Search</span>
          </div>
          <div class="cy-step <%= settings.profile && settings.profile.preferences && (settings.profile.preferences.remote_only || settings.profile.preferences.preferred_tech_stack.length > 0) ? 'done' : '' %>">
            <span class="cy-step-num">2</span>
            <span class="cy-step-label">Your Preferences</span>
          </div>
        </div>

        <!-- Section 1: Configuration -->
        <section class="cy-section" id="config">
          <h2>1. API Key & Search Settings</h2>
          <p class="cy-section-desc">Enter your NVIDIA API key and configure job search preferences. No LinkedIn login needed.</p>

          <form method="POST" action="/setup/config" class="cy-form">
            <div class="cy-form-group">
              <label for="NVIDIA_API_KEY">NVIDIA API Key</label>
              <input type="password" id="NVIDIA_API_KEY" name="NVIDIA_API_KEY"
                value="<%= apiKey || '' %>"
                placeholder="nvapi-...">
            </div>

            <hr class="cy-form-divider">

            <div class="cy-form-group">
              <label for="JOB_KEYWORDS">Job Search Keywords <span class="cy-hint">(comma-separated)</span></label>
              <input type="text" id="JOB_KEYWORDS" name="JOB_KEYWORDS"
                value="<%= settings.search.keywords.join(', ') %>"
                placeholder="software engineer, full stack developer, ml engineer">
            </div>

            <div class="cy-form-group">
              <label for="JOB_LOCATIONS">Preferred Locations <span class="cy-hint">(comma-separated, optional)</span></label>
              <input type="text" id="JOB_LOCATIONS" name="JOB_LOCATIONS"
                value="<%= settings.search.locations.join(', ') %>"
                placeholder="Remote, New York, San Francisco">
            </div>

            <hr class="cy-form-divider">

            <div class="cy-form-group">
              <label for="UI_PORT">UI Port</label>
              <input type="number" id="UI_PORT" name="UI_PORT"
                value="<%= settings.ui.port %>" min="1000" max="65535">
            </div>

            <button type="submit" class="cy-btn cy-btn-primary cy-btn-lg">Save Configuration</button>
          </form>
        </section>

        <!-- Section 2: Profile Preferences -->
        <section class="cy-section" id="profile">
          <h2>2. Your Preferences</h2>
          <p class="cy-section-desc">Tell us about your job preferences so the AI can score matches more accurately.</p>

          <form method="POST" action="/setup/profile" class="cy-form">
            <div class="cy-form-row">
              <div class="cy-form-group">
                <label class="cy-checkbox-label">
                  <input type="checkbox" name="remote_only"
                    <%= settings.profile.preferences.remote_only ? 'checked' : '' %>>
                  Remote only
                </label>
              </div>
              <div class="cy-form-group">
                <label class="cy-checkbox-label">
                  <input type="checkbox" name="willing_to_relocate"
                    <%= settings.profile.preferences.willing_to_relocate ? 'checked' : '' %>>
                  Willing to relocate
                </label>
              </div>
              <div class="cy-form-group">
                <label class="cy-checkbox-label">
                  <input type="checkbox" name="open_to_contract"
                    <%= settings.profile.additional_info.open_to_contract ? 'checked' : '' %>>
                  Open to contract work
                </label>
              </div>
              <div class="cy-form-group">
                <label class="cy-checkbox-label">
                  <input type="checkbox" name="visa_sponsorship_needed"
                    <%= settings.profile.additional_info.visa_sponsorship_needed ? 'checked' : '' %>>
                  Need visa sponsorship
                </label>
              </div>
            </div>

            <div class="cy-form-group">
              <label for="target_seniority">Target Seniority Level <span class="cy-hint">(comma-separated)</span></label>
              <input type="text" id="target_seniority" name="target_seniority"
                value="<%= settings.profile.preferences.target_seniority.join(', ') %>"
                placeholder="junior, mid, entry-level">
              <span class="cy-hint">Jobs above this level (senior, staff, lead, etc.) will be auto-rejected</span>
            </div>

            <div class="cy-form-group">
              <label for="exclude_title_keywords">Exclude Title Keywords <span class="cy-hint">(comma-separated)</span></label>
              <textarea id="exclude_title_keywords" name="exclude_title_keywords" rows="3"
                placeholder="senior, staff, principal, lead, embedded, QA, test engineer, guidewire, SAP"><%= settings.profile.preferences.exclude_title_keywords.join(', ') %></textarea>
              <span class="cy-hint">Jobs with any of these words in the title are instantly rejected before the AI even sees them</span>
            </div>

            <div class="cy-form-group">
              <label for="include_title_patterns">Include Title Patterns <span class="cy-hint">(comma-separated)</span></label>
              <textarea id="include_title_patterns" name="include_title_patterns" rows="3"
                placeholder="software engineer, developer, frontend, backend, full stack, mobile, web developer, AI engineer"><%= (settings.profile.preferences.include_title_patterns || []).join(', ') %></textarea>
              <span class="cy-hint">Only titles containing at least one of these patterns will be considered. Leave empty to disable.</span>
            </div>

            <div class="cy-form-group">
              <label for="job_search_description">What Kind of Roles Are You Looking For?</label>
              <textarea id="job_search_description" name="job_search_description" rows="4"
                placeholder="Example: I'm looking for roles where I'll be building software products..."><%= settings.profile.job_search_description || '' %></textarea>
              <span class="cy-hint">Plain English description of the work you want. The AI uses this to judge job relevance.</span>
            </div>

            <div class="cy-form-group">
              <label for="missionStatement">Your Mission / What Excites You</label>
              <textarea id="missionStatement" name="missionStatement" rows="4"
                placeholder="Example: I'm passionate about startups building AI agents and AI products."><%= settings.profile.missionStatement || '' %></textarea>
              <span class="cy-hint">What motivates you beyond job type. The AI uses this to identify jobs that align with your personal goals and passions.</span>
            </div>

            <div class="cy-form-group">
              <label for="urgencySignals">Urgency Signals</label>
              <textarea id="urgencySignals" name="urgencySignals" rows="4"
                placeholder="Example: Direct contact info in the posting, founding engineer roles, startup building AI/ML products."><%= settings.profile.urgencySignals || '' %></textarea>
              <span class="cy-hint">What should make the AI flag a job as "urgent" -- situations where you should act immediately.</span>
            </div>

            <hr class="cy-form-divider">

            <div class="cy-form-group">
              <label for="preferred_company_size">Preferred Company Size <span class="cy-hint">(comma-separated)</span></label>
              <input type="text" id="preferred_company_size" name="preferred_company_size"
                value="<%= settings.profile.preferences.preferred_company_size.join(', ') %>"
                placeholder="startup, medium, large">
            </div>

            <div class="cy-form-group">
              <label for="preferred_tech_stack">Preferred Tech Stack <span class="cy-hint">(comma-separated)</span></label>
              <input type="text" id="preferred_tech_stack" name="preferred_tech_stack"
                value="<%= settings.profile.preferences.preferred_tech_stack.join(', ') %>"
                placeholder="TypeScript, React, Node.js, Python">
            </div>

            <div class="cy-form-group">
              <label for="avoid_industries">Industries to Avoid <span class="cy-hint">(comma-separated)</span></label>
              <input type="text" id="avoid_industries" name="avoid_industries"
                value="<%= settings.profile.preferences.avoid_industries.join(', ') %>"
                placeholder="finance, defense, gambling">
            </div>

            <div class="cy-form-group">
              <label for="key_interests">Key Interests <span class="cy-hint">(comma-separated)</span></label>
              <input type="text" id="key_interests" name="key_interests"
                value="<%= settings.profile.additional_info.key_interests.join(', ') %>"
                placeholder="AI/ML, developer tools, automation">
            </div>

            <div class="cy-form-group">
              <label for="min_salary">Minimum Salary (USD)</label>
              <input type="number" id="min_salary" name="min_salary"
                value="<%= settings.profile.additional_info.min_salary || '' %>"
                placeholder="120000" min="0" step="5000">
            </div>

            <div class="cy-form-group">
              <label for="dealbreakers">Dealbreakers <span class="cy-hint">(comma-separated)</span></label>
              <input type="text" id="dealbreakers" name="dealbreakers"
                value="<%= settings.profile.dealbreakers.join(', ') %>"
                placeholder="5 days in office, no remote option, unpaid overtime">
            </div>

            <button type="submit" class="cy-btn cy-btn-primary cy-btn-lg">Save Preferences</button>
          </form>
        </section>

        <!-- Section 3: Import / Export Settings -->
        <section class="cy-section" id="import-export">
          <h2>3. Import / Export Settings</h2>
          <p class="cy-section-desc">Export your current settings as a JSON file, or import a previously exported one. This includes search settings, scraper config, and profile preferences -- everything except the API key.</p>

          <div class="cy-import-export-row">
            <a href="/setup/export" class="cy-btn cy-btn-primary" style="text-decoration: none;">Export Settings JSON</a>

            <form method="POST" action="/setup/import" enctype="multipart/form-data" class="cy-form" style="margin: 0; flex: 1; min-width: 250px;">
              <div style="display: flex; gap: 8px; align-items: center;">
                <div class="cy-file-upload" style="flex: 1;">
                  <input type="file" id="settings_file" name="settings_file" accept=".json,application/json">
                </div>
                <button type="submit" class="cy-btn cy-btn-primary">Import</button>
              </div>
            </form>
          </div>

          <p class="cy-hint" style="margin-top: 12px;">Importing a settings file will replace all current settings (except your API key and resume).</p>
        </section>

      </div>
    </main>
  </div>
</body>
</html>
