<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Profile - Job Tracker</title>
</head>
<body>
  <div class="cy-app">
    <%- include('partials/sidebar', { activePage: 'profile' }) %>

    <main class="cy-main">
      <div class="cy-page cy-profile-page">

        <!-- Breadcrumb -->
        <div class="cy-breadcrumb">
          <a href="/">Home</a>
          <span class="cy-breadcrumb-sep">></span>
          <span style="color: var(--text-secondary);">Profile</span>
        </div>

        <!-- Page Header -->
        <div class="cy-page-header">
          <h1>Your Profile</h1>
        </div>

        <!-- Section Nav -->
        <div class="cy-profile-nav">
          <a href="#personal" class="cy-profile-nav-link">Personal</a>
          <a href="#experience" class="cy-profile-nav-link">Experience</a>
          <a href="#education" class="cy-profile-nav-link">Education</a>
          <a href="#skills" class="cy-profile-nav-link">Skills</a>
          <a href="#documents" class="cy-profile-nav-link">Documents</a>
        </div>

        <!-- PERSONAL INFO -->
        <section class="cy-section" id="personal">
          <div class="cy-section-header-row">
            <h2>Personal Information</h2>
            <span class="cy-save-indicator" id="personal-save-indicator"></span>
          </div>
          <p class="cy-section-desc">Changes save automatically on blur.</p>

          <div class="cy-section-body">
            <div class="cy-personal-grid">
              <div class="cy-field-group" data-field="firstName">
                <div class="cy-inline-label">First Name</div>
                <input type="text" class="cy-ghost-input" value="<%= profile.firstName %>" placeholder="John">
              </div>
              <div class="cy-field-group" data-field="lastName">
                <div class="cy-inline-label">Last Name</div>
                <input type="text" class="cy-ghost-input" value="<%= profile.lastName %>" placeholder="Doe">
              </div>
              <div class="cy-field-group" data-field="email">
                <div class="cy-inline-label">Email</div>
                <input type="email" class="cy-ghost-input" value="<%= profile.email %>" placeholder="john@example.com">
              </div>
              <div class="cy-field-group" data-field="phone">
                <div class="cy-inline-label">Phone</div>
                <input type="text" class="cy-ghost-input" value="<%= profile.phone %>" placeholder="+1 (555) 123-4567">
              </div>
              <div class="cy-field-group" data-field="linkedinUrl">
                <div class="cy-inline-label">LinkedIn URL</div>
                <input type="text" class="cy-ghost-input" value="<%= profile.linkedinUrl %>" placeholder="https://linkedin.com/in/johndoe">
              </div>
              <div class="cy-field-group" data-field="website">
                <div class="cy-inline-label">Website / Portfolio</div>
                <input type="text" class="cy-ghost-input" value="<%= profile.website %>" placeholder="https://johndoe.dev">
              </div>
              <div class="cy-field-group" data-field="city">
                <div class="cy-inline-label">City</div>
                <input type="text" class="cy-ghost-input" value="<%= profile.city %>" placeholder="San Francisco">
              </div>
              <div class="cy-field-group" data-field="state">
                <div class="cy-inline-label">State</div>
                <input type="text" class="cy-ghost-input" value="<%= profile.state %>" placeholder="CA">
              </div>
              <div class="cy-field-group" data-field="country">
                <div class="cy-inline-label">Country</div>
                <input type="text" class="cy-ghost-input" value="<%= profile.country %>" placeholder="United States">
              </div>
              <div class="cy-field-group" data-field="zipCode">
                <div class="cy-inline-label">Zip Code</div>
                <input type="text" class="cy-ghost-input" value="<%= profile.zipCode %>" placeholder="94105">
              </div>
              <div class="cy-field-group full-width" data-field="summary">
                <div class="cy-inline-label">Professional Summary</div>
                <textarea class="cy-ghost-textarea" rows="4" placeholder="Brief elevator pitch about yourself..."><%= profile.summary %></textarea>
              </div>
            </div>
          </div>
        </section>

        <!-- WORK EXPERIENCE -->
        <section class="cy-section" id="experience">
          <h2>Work Experience</h2>
          <p class="cy-section-desc">Your employment history. Used by the AI to build your profile summary.</p>

          <div class="cy-section-body">
            <% if (profile.workExperience.length > 0) { %>
              <div class="cy-profile-items">
                <% profile.workExperience.forEach(function(exp) { %>
                  <div class="cy-profile-item">
                    <div class="cy-profile-item-header">
                      <div>
                        <strong><%= exp.title %></strong> at <strong><%= exp.employer %></strong>
                        <% if (exp.location) { %><span class="cy-hint"> &mdash; <%= exp.location %></span><% } %>
                      </div>
                      <div class="cy-profile-item-dates">
                        <%= exp.startDate %> &ndash; <%= exp.isCurrent ? 'Present' : (exp.endDate || '?') %>
                      </div>
                    </div>
                    <% if (exp.description) { %>
                      <p class="cy-profile-item-desc"><%= exp.description %></p>
                    <% } %>
                    <div class="cy-profile-item-actions">
                      <button type="button" class="cy-btn-toggle" onclick="toggleEdit('exp-<%= exp.id %>')">Edit</button>
                      <form method="POST" action="/profile/experience/<%= exp.id %>/delete" class="inline-form">
                        <button type="submit" class="cy-btn-delete" onclick="return confirm('Delete this entry?')">Delete</button>
                      </form>
                    </div>
                    <!-- Edit form (hidden) -->
                    <div class="cy-profile-edit-form" id="exp-<%= exp.id %>" style="display: none;">
                      <form method="POST" action="/profile/experience/<%= exp.id %>" class="cy-form cy-form-minimal">
                        <div class="cy-form-row">
                          <div class="cy-form-group"><label>Title</label><input type="text" name="title" value="<%= exp.title %>" required></div>
                          <div class="cy-form-group"><label>Employer</label><input type="text" name="employer" value="<%= exp.employer %>" required></div>
                        </div>
                        <div class="cy-form-row">
                          <div class="cy-form-group"><label>Location</label><input type="text" name="location" value="<%= exp.location %>"></div>
                          <div class="cy-form-group"><label>Start Date</label><input type="text" name="startDate" value="<%= exp.startDate %>" placeholder="2023-01" required></div>
                          <div class="cy-form-group"><label>End Date</label><input type="text" name="endDate" value="<%= exp.endDate || '' %>" placeholder="2024-06"></div>
                        </div>
                        <div class="cy-form-group"><label class="cy-checkbox-label"><input type="checkbox" name="isCurrent" <%= exp.isCurrent ? 'checked' : '' %>> Current position</label></div>
                        <div class="cy-form-group"><label>Description</label><textarea name="description" rows="3"><%= exp.description %></textarea></div>
                        <button type="submit" class="cy-btn-inline">Update</button>
                      </form>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } %>

            <!-- Add new -->
            <details class="cy-add-section">
              <summary class="cy-btn-add">+ Add Work Experience</summary>
              <form method="POST" action="/profile/experience" class="cy-form cy-form-minimal" style="margin-top: 16px;">
                <div class="cy-form-row">
                  <div class="cy-form-group"><label>Job Title</label><input type="text" name="title" placeholder="Software Engineer" required></div>
                  <div class="cy-form-group"><label>Employer</label><input type="text" name="employer" placeholder="Acme Corp" required></div>
                </div>
                <div class="cy-form-row">
                  <div class="cy-form-group"><label>Location</label><input type="text" name="location" placeholder="San Francisco, CA"></div>
                  <div class="cy-form-group"><label>Start Date</label><input type="text" name="startDate" placeholder="2023-01" required></div>
                  <div class="cy-form-group"><label>End Date</label><input type="text" name="endDate" placeholder="2024-06 (or leave blank)"></div>
                </div>
                <div class="cy-form-group"><label class="cy-checkbox-label"><input type="checkbox" name="isCurrent"> Current position</label></div>
                <div class="cy-form-group"><label>Description</label><textarea name="description" rows="3" placeholder="Key responsibilities and achievements..."></textarea></div>
                <button type="submit" class="cy-btn-inline">Add Experience</button>
              </form>
            </details>
          </div>
        </section>

        <!-- EDUCATION -->
        <section class="cy-section" id="education">
          <h2>Education</h2>
          <p class="cy-section-desc">Your educational background.</p>

          <div class="cy-section-body">
            <% if (profile.education.length > 0) { %>
              <div class="cy-profile-items">
                <% profile.education.forEach(function(edu) { %>
                  <div class="cy-profile-item">
                    <div class="cy-profile-item-header">
                      <div>
                        <strong><%= edu.degree %></strong><% if (edu.fieldOfStudy) { %> in <%= edu.fieldOfStudy %><% } %>
                        <br><span class="cy-hint"><%= edu.institution %></span>
                      </div>
                      <div class="cy-profile-item-dates">
                        <%= edu.startDate || '' %><% if (edu.startDate && edu.endDate) { %> &ndash; <% } %><%= edu.endDate || '' %>
                        <% if (edu.gpa) { %><br><span class="cy-hint">GPA: <%= edu.gpa %></span><% } %>
                      </div>
                    </div>
                    <div class="cy-profile-item-actions">
                      <button type="button" class="cy-btn-toggle" onclick="toggleEdit('edu-<%= edu.id %>')">Edit</button>
                      <form method="POST" action="/profile/education/<%= edu.id %>/delete" class="inline-form">
                        <button type="submit" class="cy-btn-delete" onclick="return confirm('Delete this entry?')">Delete</button>
                      </form>
                    </div>
                    <div class="cy-profile-edit-form" id="edu-<%= edu.id %>" style="display: none;">
                      <form method="POST" action="/profile/education/<%= edu.id %>" class="cy-form cy-form-minimal">
                        <div class="cy-form-row">
                          <div class="cy-form-group"><label>Institution</label><input type="text" name="institution" value="<%= edu.institution %>" required></div>
                          <div class="cy-form-group"><label>Degree</label><input type="text" name="degree" value="<%= edu.degree %>" required></div>
                        </div>
                        <div class="cy-form-row">
                          <div class="cy-form-group"><label>Field of Study</label><input type="text" name="fieldOfStudy" value="<%= edu.fieldOfStudy %>"></div>
                          <div class="cy-form-group"><label>GPA</label><input type="text" name="gpa" value="<%= edu.gpa || '' %>"></div>
                        </div>
                        <div class="cy-form-row">
                          <div class="cy-form-group"><label>Start Date</label><input type="text" name="startDate" value="<%= edu.startDate || '' %>" placeholder="2019-09"></div>
                          <div class="cy-form-group"><label>End Date</label><input type="text" name="endDate" value="<%= edu.endDate || '' %>" placeholder="2023-06"></div>
                        </div>
                        <button type="submit" class="cy-btn-inline">Update</button>
                      </form>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } %>

            <details class="cy-add-section">
              <summary class="cy-btn-add">+ Add Education</summary>
              <form method="POST" action="/profile/education" class="cy-form cy-form-minimal" style="margin-top: 16px;">
                <div class="cy-form-row">
                  <div class="cy-form-group"><label>Institution</label><input type="text" name="institution" placeholder="Stanford University" required></div>
                  <div class="cy-form-group"><label>Degree</label><input type="text" name="degree" placeholder="B.S." required></div>
                </div>
                <div class="cy-form-row">
                  <div class="cy-form-group"><label>Field of Study</label><input type="text" name="fieldOfStudy" placeholder="Computer Science"></div>
                  <div class="cy-form-group"><label>GPA</label><input type="text" name="gpa" placeholder="3.8"></div>
                </div>
                <div class="cy-form-row">
                  <div class="cy-form-group"><label>Start Date</label><input type="text" name="startDate" placeholder="2019-09"></div>
                  <div class="cy-form-group"><label>End Date</label><input type="text" name="endDate" placeholder="2023-06"></div>
                </div>
                <button type="submit" class="cy-btn-inline">Add Education</button>
              </form>
            </details>
          </div>
        </section>

        <!-- SKILLS -->
        <section class="cy-section" id="skills">
          <h2>Skills</h2>
          <p class="cy-section-desc">Technical and non-technical skills. These help the AI match you to relevant positions.</p>

          <div class="cy-section-body">
            <% if (profile.skills.length > 0) { %>
              <div class="cy-skill-tags">
                <% profile.skills.forEach(function(skill) { %>
                  <div class="cy-skill-tag">
                    <span class="cy-skill-name"><%= skill.name %></span>
                    <% if (skill.category !== 'technical') { %><span class="cy-skill-cat"><%= skill.category %></span><% } %>
                    <% if (skill.yearsOfExperience) { %><span class="cy-skill-years"><%= skill.yearsOfExperience %>y</span><% } %>
                    <form method="POST" action="/profile/skill/<%= skill.id %>/delete" class="inline-form">
                      <button type="submit" class="cy-skill-remove" title="Remove">&times;</button>
                    </form>
                  </div>
                <% }); %>
              </div>
            <% } %>

            <details class="cy-add-section">
              <summary class="cy-btn-add">+ Add Skill</summary>
              <form method="POST" action="/profile/skill" class="cy-form cy-form-minimal" style="margin-top: 16px;">
                <div class="cy-form-row">
                  <div class="cy-form-group"><label>Skill Name</label><input type="text" name="name" placeholder="React" required></div>
                  <div class="cy-form-group">
                    <label>Category</label>
                    <select name="category">
                      <option value="technical">Technical</option>
                      <option value="language">Language</option>
                      <option value="soft-skill">Soft Skill</option>
                      <option value="tool">Tool</option>
                      <option value="other">Other</option>
                    </select>
                  </div>
                  <div class="cy-form-group"><label>Years of Experience</label><input type="number" name="yearsOfExperience" placeholder="3" min="0" max="50"></div>
                  <div class="cy-form-group">
                    <label>Proficiency</label>
                    <select name="proficiency">
                      <option value="">--</option>
                      <option value="beginner">Beginner</option>
                      <option value="intermediate">Intermediate</option>
                      <option value="advanced">Advanced</option>
                      <option value="expert">Expert</option>
                    </select>
                  </div>
                </div>
                <button type="submit" class="cy-btn-inline">Add Skill</button>
              </form>
            </details>
          </div>
        </section>

        <!-- DOCUMENTS -->
        <section class="cy-section" id="documents">
          <h2>Documents</h2>
          <p class="cy-section-desc">Upload your resume and other documents. The primary resume is used by the AI for profile matching.</p>

          <div class="cy-section-body">
            <% if (profile.documents.length > 0) { %>
              <div class="cy-doc-list">
                <% profile.documents.forEach(function(doc) { %>
                  <div class="cy-doc-item">
                    <div class="cy-doc-info">
                      <div class="cy-doc-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                      </div>
                      <div>
                        <strong style="color: var(--text-primary);"><%= doc.filename %></strong>
                        <% if (doc.isPrimary) { %><span class="cy-status applied" style="margin-left: 8px; font-size: 10px;">Primary</span><% } %>
                        <br><span class="cy-hint"><%= doc.type %> &middot; <%= (doc.sizeBytes / 1024).toFixed(0) %> KB &middot; <%= new Date(doc.uploadedAt).toLocaleDateString() %></span>
                      </div>
                    </div>
                    <div class="cy-doc-actions">
                      <% if (!doc.isPrimary && doc.type === 'resume') { %>
                        <form method="POST" action="/profile/document/<%= doc.id %>/primary" class="inline-form">
                          <button type="submit" class="cy-btn-toggle">Set Primary</button>
                        </form>
                      <% } %>
                      <form method="POST" action="/profile/document/<%= doc.id %>/delete" class="inline-form">
                        <button type="submit" class="cy-btn-delete" onclick="return confirm('Delete this document?')">Delete</button>
                      </form>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div class="cy-hint" style="padding: 20px 0;">No documents uploaded yet.</div>
            <% } %>

            <details class="cy-add-section">
              <summary class="cy-btn-add">+ Upload Document</summary>
              <form method="POST" action="/profile/document" enctype="multipart/form-data" class="cy-form cy-form-minimal" style="margin-top: 16px;">
                <div class="cy-form-row">
                  <div class="cy-form-group">
                    <label>Document Type</label>
                    <select name="docType">
                      <option value="resume">Resume</option>
                      <option value="other">Other</option>
                    </select>
                  </div>
                  <div class="cy-form-group">
                    <label class="cy-checkbox-label" style="margin-top: 28px;">
                      <input type="checkbox" name="isPrimary" checked>
                      Set as primary
                    </label>
                  </div>
                </div>
                <div class="cy-form-group">
                  <label>File (PDF or Word)</label>
                  <div class="cy-file-upload">
                    <input type="file" name="document" accept=".pdf,.doc,.docx" required>
                  </div>
                </div>
                <button type="submit" class="cy-btn-inline">Upload</button>
              </form>
            </details>
          </div>
        </section>

      </div>
    </main>
  </div>

  <script>
    function toggleEdit(id) {
      var el = document.getElementById(id);
      if (el) {
        el.style.display = el.style.display === 'none' ? 'block' : 'none';
      }
    }

    // ── Auto-save for Personal Info ──
    (function() {
      var indicator = document.getElementById('personal-save-indicator');
      var fields = document.querySelectorAll('#personal .cy-field-group[data-field]');
      var hideTimer = null;

      function flash(state, text) {
        indicator.textContent = text;
        indicator.className = 'cy-save-indicator visible ' + state;
        clearTimeout(hideTimer);
        if (state !== 'saving') {
          hideTimer = setTimeout(function() {
            indicator.classList.remove('visible');
          }, 2000);
        }
      }

      fields.forEach(function(group) {
        var input = group.querySelector('.cy-ghost-input, .cy-ghost-textarea');
        var fieldName = group.getAttribute('data-field');
        var lastSaved = input.value;

        input.addEventListener('blur', function() {
          var val = input.value.trim();
          if (val === lastSaved) return;
          lastSaved = val;

          flash('saving', 'Saving...');
          var body = {};
          body[fieldName] = val;

          fetch('/api/profile/personal', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
          })
          .then(function(r) { return r.json(); })
          .then(function(d) { flash(d.ok ? 'saved' : 'error', d.ok ? 'Saved' : 'Error'); })
          .catch(function() { flash('error', 'Error'); });
        });

        input.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' && input.tagName !== 'TEXTAREA') {
            e.preventDefault();
            input.blur();
          } else if (e.key === 'Escape') {
            input.value = lastSaved;
            input.blur();
          }
        });
      });
    })();
  </script>
</body>
</html>
