<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Jobs - Job Tracker</title>
</head>
<body>
  <div class="cy-app">
    <%- include('partials/sidebar', { activePage: 'jobs' }) %>

    <main class="cy-main">
      <div class="cy-page cy-page--jobs">

        <!-- Page Header (compact, no breadcrumb to save vertical space) -->
        <div class="jb-header">
          <div class="jb-header-left">
            <h1>Jobs</h1>
            <span class="jb-header-count"><%= jobs.length %> total</span>
          </div>
          <div class="jb-header-right">
            <button class="cy-export-btn" onclick="window.print()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Export
            </button>
          </div>
        </div>

        <!-- Filter Chips -->
        <div class="cy-filters">
          <a href="/jobs" class="cy-chip <%= currentFilter === 'new' ? 'active' : '' %>">New (<%= stats.statusCounts.new || 0 %>)</a>
          <a href="/jobs?status=all" class="cy-chip <%= currentFilter === 'all' ? 'active' : '' %>">All (<%= stats.totalJobs %>)</a>
          <% statuses.filter(function(s) { return s !== 'new'; }).forEach(function(status) { %>
            <a href="/jobs?status=<%= status %>" class="cy-chip <%= currentFilter === status ? 'active' : '' %>">
              <%= status.charAt(0).toUpperCase() + status.slice(1) %> (<%= stats.statusCounts[status] || 0 %>)
            </a>
          <% }); %>
        </div>

        <!-- ============================================================
             SPLIT-PANE MASTER/DETAIL LAYOUT
             ============================================================ -->
        <div class="jb-split">

          <!-- LEFT: Job List Panel -->
          <div class="jb-list-panel" id="jb-list-panel">
            <% if (jobs.length === 0) { %>
              <div class="cy-empty" style="padding: 60px 20px;">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" style="margin-bottom: 16px; opacity: 0.4;">
                  <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                </svg>
                <p>No jobs found.<br>
                <% if (currentFilter !== 'all') { %>
                  Try a different filter or <a href="/jobs">view all</a>.
                <% } else { %>
                  The scraper hasn't found any matching jobs yet.
                <% } %>
                </p>
              </div>
            <% } else { %>
              <div class="jb-list" id="jb-list">
                <% jobs.forEach(function(job, index) { %>
                  <div class="jb-card<%= job.priority === 'urgent' ? ' jb-card--urgent' : job.priority === 'high' ? ' jb-card--high' : '' %>"
                       data-job-id="<%= job.id %>"
                       onclick="selectJob('<%= job.id %>')"
                       tabindex="0"
                       role="button"
                       aria-label="View details for <%= job.title %> at <%= job.company %>">

                    <div class="jb-card-top">
                      <div class="jb-card-badges">
                        <% if (job.priority && job.priority !== 'normal' && job.priority !== 'low') { %>
                          <span class="cy-priority <%= job.priority %>"><%= job.priority.toUpperCase() %></span>
                        <% } %>
                        <% if (job.enrichmentStatus === 'pending') { %>
                          <span class="cy-enrichment-pending">Analyzing...</span>
                        <% } %>
                        <span class="cy-status <%= job.status %>"><%= job.status %></span>
                      </div>
                      <span class="jb-card-score <%= job.matchScore >= 85 ? 'excellent' : job.matchScore >= 70 ? 'good' : job.matchScore >= 50 ? 'decent' : job.matchScore > 0 ? 'low' : 'none' %>">
                        <%= job.matchScore %>
                      </span>
                    </div>

                    <div class="jb-card-title"><%= job.title %></div>
                    <div class="jb-card-company"><%= job.company %><% if (job.location) { %> &middot; <%= job.location %><% } %></div>

                    <div class="jb-card-meta">
                      <span class="jb-card-date">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <%= job.postedDate || 'Unknown' %>
                      </span>
                      <% if (job.employmentType) { %>
                        <span class="jb-card-type"><%= job.employmentType %></span>
                      <% } %>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } %>
          </div>

          <!-- RIGHT: Detail Panel (persistent, not a modal) -->
          <div class="jb-detail-panel" id="jb-detail-panel">

            <!-- Empty state (shown when no job is selected) -->
            <div class="jb-detail-empty" id="jb-detail-empty">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1" style="opacity: 0.3;">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
              </svg>
              <div class="jb-detail-empty-title">Select a job to view details</div>
              <div class="jb-detail-empty-sub">Click any job from the list to see its full information, enrichment data, and controls.</div>
            </div>

            <!-- Detail content (hidden until a job is selected) -->
            <div class="jb-detail-content" id="jb-detail-content" style="display: none;">

              <!-- Detail header -->
              <div class="jb-detail-header" id="jb-detail-header">
                <div class="jb-detail-title-row">
                  <h2 class="jb-detail-title" id="jb-detail-title"></h2>
                  <!-- Mobile close button -->
                  <button class="jb-detail-close-mobile" id="jb-detail-close-mobile" onclick="deselectJob()" aria-label="Close detail panel">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </button>
                </div>
                <div class="jb-detail-subtitle" id="jb-detail-subtitle"></div>
              </div>

              <!-- Action bar -->
              <div class="jb-detail-actions" id="jb-detail-actions"></div>

              <!-- Tab bar -->
              <div class="jb-tab-bar">
                <button class="jb-tab jb-tab--active" id="jb-tab-info" onclick="switchDetailTab('info')">Info</button>
                <button class="jb-tab" id="jb-tab-chat" onclick="switchDetailTab('chat')">Chat</button>
              </div>

              <!-- Tab: Info (scrollable job body) -->
              <div class="jb-detail-body" id="jb-detail-body"></div>

              <!-- Tab: Chat -->
              <div class="jb-chat" id="jb-chat" style="display: none;">
                <div class="jb-chat-messages" id="jb-chat-messages">
                </div>
                <div class="jb-chat-input-row">
                  <button class="jb-chat-clear-btn" onclick="clearChat()" title="Clear chat">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </button>
                  <textarea class="jb-chat-input" id="jb-chat-input" placeholder="Ask about this job or request a message draft..." rows="1" onkeydown="handleChatKeydown(event)"></textarea>
                  <button class="jb-chat-send" id="jb-chat-send" onclick="sendChatMessage()" title="Send">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>

        </div><!-- /jb-split -->
      </div>
    </main>
  </div>

  <script>
    var allJobs = <%- JSON.stringify(jobs.map(function(job) { return job; })) %>;
    var selectedJobId = null;

    function findJob(id) {
      return allJobs.find(function(j) { return j.id === id; });
    }

    function escapeHtml(str) {
      if (!str) return '';
      var div = document.createElement('div');
      div.appendChild(document.createTextNode(String(str)));
      return div.innerHTML;
    }

    /**
     * Select a job from the list and render its details in the right panel.
     */
    function selectJob(id) {
      var job = findJob(id);
      if (!job) return;

      selectedJobId = id;

      // Update active state in list
      var cards = document.querySelectorAll('.jb-card');
      cards.forEach(function(card) {
        card.classList.toggle('jb-card--active', card.getAttribute('data-job-id') === id);
      });

      // Show detail content, hide empty state
      document.getElementById('jb-detail-empty').style.display = 'none';
      document.getElementById('jb-detail-content').style.display = 'flex';

      // On mobile, add class to show detail panel full screen
      document.getElementById('jb-detail-panel').classList.add('jb-detail-panel--active');

      // Render title
      document.getElementById('jb-detail-title').textContent = job.title;

      // Subtitle (company + location + date)
      var subtitle = escapeHtml(job.company);
      if (job.location) subtitle += ' &middot; ' + escapeHtml(job.location);
      if (job.postedDate) subtitle += ' &middot; ' + escapeHtml(job.postedDate);
      document.getElementById('jb-detail-subtitle').innerHTML = subtitle;

      // ---- Action buttons ----
      var actionsHtml = '<div class="jb-action-row">';
      // Primary links (left side)
      actionsHtml += '<div class="jb-action-links">';
      if (job.applyLink) {
        actionsHtml += '<a href="' + escapeHtml(job.applyLink) + '" target="_blank" rel="noopener noreferrer" class="cy-btn cy-btn-primary">Apply Now</a>';
        actionsHtml += '<a href="' + escapeHtml(job.link) + '" target="_blank" rel="noopener noreferrer" class="cy-btn cy-btn-outline">View on LinkedIn</a>';
      } else {
        actionsHtml += '<a href="' + escapeHtml(job.link) + '" target="_blank" rel="noopener noreferrer" class="cy-btn cy-btn-primary">Apply on LinkedIn</a>';
      }
      actionsHtml += '</div>';
      // Decision buttons (right side)
      actionsHtml += '<div class="jb-decision-actions">';
      if (job.status === 'new') {
        // Show accept + reject for new jobs
        actionsHtml += '<form method="POST" action="/update-status" class="jb-status-form inline-form"><input type="hidden" name="id" value="' + job.id + '"><button type="submit" name="status" value="accepted" class="jb-decision-btn jb-decision-btn--accept" title="Accept"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg></button></form>';
        actionsHtml += '<form method="POST" action="/update-status" class="jb-status-form inline-form"><input type="hidden" name="id" value="' + job.id + '"><button type="submit" name="status" value="rejected" class="jb-decision-btn jb-decision-btn--reject" title="Reject"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></form>';
      }
      // Show "Mark Applied" as a subtle sub-action for accepted jobs
      if (job.status === 'accepted') {
        actionsHtml += '<form method="POST" action="/update-status" class="jb-status-form inline-form"><input type="hidden" name="id" value="' + job.id + '"><button type="submit" name="status" value="applied" class="jb-action-btn jb-action-btn--applied"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Mark Applied</button></form>';
      }
      actionsHtml += '</div>';
      actionsHtml += '</div>';
      // "Already Applied" below the action row for new jobs
      if (job.status === 'new') {
        actionsHtml += '<div class="jb-already-applied-row"><form method="POST" action="/update-status" class="jb-status-form inline-form"><input type="hidden" name="id" value="' + job.id + '"><button type="submit" name="status" value="applied" class="jb-action-btn jb-action-btn--applied" title="Already Applied"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>Already Applied</button></form></div>';
      }
      document.getElementById('jb-detail-actions').innerHTML = actionsHtml;

      // ---- Body ----
      var bodyHtml = '';
      var scoreClass = job.matchScore >= 85 ? 'excellent' : job.matchScore >= 70 ? 'good' : job.matchScore >= 50 ? 'decent' : job.matchScore > 0 ? 'low' : 'none';

      // ---- 1. Dealbreaker banner ----
      if (job.enrichmentStatus === 'enriched' && job.dealbreakerDisplay) {
        var dealbreakLabels = {
          seniorityTooHigh: 'Seniority too high',
          clearanceRequired: 'Security clearance required',
          wrongTechDomain: 'Wrong tech domain',
          experienceRequires6Plus: 'Requires 6+ years experience'
        };
        bodyHtml += '<div class="jb-dealbreaker-banner">';
        bodyHtml += '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';
        bodyHtml += '<div><strong>Dealbreaker</strong><br>' + escapeHtml(dealbreakLabels[job.dealbreakerDisplay] || job.dealbreakerDisplay) + '</div>';
        bodyHtml += '</div>';
      }

      // ---- 2. Priority callout + Red flags (verdict) ----
      if (job.enrichmentStatus === 'enriched' && !job.dealbreakerDisplay && (job.priorityReason || (job.redFlagsParsed && job.redFlagsParsed.length > 0))) {
        bodyHtml += '<div class="jb-verdict jb-verdict--' + (job.priority || 'normal') + '">';

        bodyHtml += '<div class="jb-verdict-topbar">';
        bodyHtml += '<div class="jb-verdict-score"><span class="jb-verdict-score-num ' + scoreClass + '">' + job.matchScore + '</span><span class="jb-verdict-score-label">Match</span></div>';
        if (job.priority) bodyHtml += '<span class="cy-priority ' + job.priority + '">' + job.priority.toUpperCase() + '</span>';
        bodyHtml += '</div>';

        if (job.priorityReason) {
          bodyHtml += '<p class="jb-verdict-reason">' + escapeHtml(job.priorityReason) + '</p>';
        }

        if (job.redFlagsParsed && job.redFlagsParsed.length > 0) {
          bodyHtml += '<div class="jb-verdict-flags">';
          bodyHtml += '<div class="jb-verdict-flags-label"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>Heads Up</div>';
          job.redFlagsParsed.forEach(function(flag) {
            bodyHtml += '<div class="jb-verdict-flag">' + escapeHtml(flag) + '</div>';
          });
          bodyHtml += '</div>';
        }

        bodyHtml += '</div>';
      }

      // ---- 3. Action Items (PROMOTED — right after verdict) ----
      if (job.enrichmentStatus === 'enriched' && job.actionItemsParsed && job.actionItemsParsed.length > 0) {
        bodyHtml += '<div class="cy-detail-section jb-action-items-prominent">';
        bodyHtml += '<div class="cy-detail-section-title">Action Items</div>';
        bodyHtml += '<ul class="cy-action-list">';
        job.actionItemsParsed.forEach(function(item) {
          bodyHtml += '<li>' + escapeHtml(item) + '</li>';
        });
        bodyHtml += '</ul></div>';
      }

      // ---- 4. Contacts (PROMOTED — right after action items) ----
      if (job.enrichmentStatus === 'enriched' && ((job.contactPeopleParsed && job.contactPeopleParsed.length > 0) || job.postedBy)) {
        bodyHtml += '<div class="cy-detail-section"><div class="cy-detail-section-title">People to Reach Out To</div>';
        if (job.postedBy) {
          bodyHtml += '<div class="cy-contact-person"><strong>Posted by:</strong>&nbsp;';
          if (job.postedByProfile) bodyHtml += '<a href="' + escapeHtml(job.postedByProfile) + '" target="_blank">' + escapeHtml(job.postedBy) + '</a>';
          else bodyHtml += escapeHtml(job.postedBy);
          if (job.postedByTitle) bodyHtml += ' <span class="cy-hint">&mdash; ' + escapeHtml(job.postedByTitle) + '</span>';
          bodyHtml += '</div>';
        }
        if (job.contactPeopleParsed) {
          job.contactPeopleParsed.forEach(function(person) {
            bodyHtml += '<div class="cy-contact-person">';
            if (person.profileUrl) bodyHtml += '<a href="' + escapeHtml(person.profileUrl) + '" target="_blank">' + escapeHtml(person.name) + '</a>';
            else bodyHtml += escapeHtml(person.name);
            if (person.title) bodyHtml += ' <span class="cy-hint">&mdash; ' + escapeHtml(person.title) + '</span>';
            bodyHtml += '</div>';
          });
        }
        bodyHtml += '</div>';
      }

      // ---- 5. Score Breakdown (collapsible, closed by default) ----
      var bd = job.scoreBreakdownParsed || {};
      var hasBreakdown = bd.techStack !== undefined && !job.dealbreakerDisplay;
      if (job.enrichmentStatus === 'enriched' && hasBreakdown) {
        bodyHtml += '<div class="cy-detail-section jb-collapsible">';
        bodyHtml += '<div class="jb-collapsible-header" onclick="toggleCollapsible(this)">';
        bodyHtml += '<span class="cy-detail-section-title">Score Breakdown</span>';
        bodyHtml += '<svg class="jb-collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>';
        bodyHtml += '</div>';
        bodyHtml += '<div class="jb-collapsible-body" style="display: none;">';
        bodyHtml += '<div class="jb-score-grid">';

        var categories = [
          { label: 'Core Fit', dims: [
            { key: 'techStack', name: 'Tech Stack', w: '10%' },
            { key: 'roleType', name: 'Building vs Maintaining', w: '9%' },
            { key: 'aiRelevance', name: 'AI/LLM Relevance', w: '12%' },
            { key: 'fullStackBreadth', name: 'Full Stack Breadth', w: '5%' },
            { key: 'productOwnership', name: 'Product Ownership', w: '6%' },
          ]},
          { label: 'Opportunity', dims: [
            { key: 'companyStage', name: 'Company Stage', w: '12%' },
            { key: 'growthPotential', name: 'Growth Potential', w: '6%' },
          ]},
          { label: 'Competitive', dims: [
            { key: 'experienceMatch', name: 'Experience Match', w: '8%' },
            { key: 'seniorityAlignment', name: 'Seniority Fit', w: '5%' },
            { key: 'applicantCompetition', name: 'Competition', w: '4%' },
            { key: 'descriptionQuality', name: 'Description Quality', w: '3%' },
            { key: 'postingFreshness', name: 'Freshness', w: '2%' },
          ]},
          { label: 'Access', dims: [
            { key: 'remotePosition', name: 'Remote', w: '12%' },
            { key: 'directContact', name: 'Direct Contact', w: '3%' },
            { key: 'posterRole', name: 'Poster Role', w: '2%' },
            { key: 'applicationMethod', name: 'Apply Method', w: '1%' },
          ]},
        ];

        categories.forEach(function(cat) {
          bodyHtml += '<div class="jb-score-cat-label">' + cat.label + '</div>';
          cat.dims.forEach(function(d) {
            var val = bd[d.key];
            if (val === undefined) val = '-';
            var pct = typeof val === 'number' ? (val / 10 * 100) : 0;
            var barClass = val >= 8 ? 'high' : val >= 5 ? 'mid' : val >= 0 ? 'low' : '';
            bodyHtml += '<div class="jb-score-row">';
            bodyHtml += '<span class="jb-score-dim-name">' + d.name + '</span>';
            bodyHtml += '<span class="jb-score-dim-weight">' + d.w + '</span>';
            bodyHtml += '<div class="jb-score-bar-track"><div class="jb-score-bar-fill ' + barClass + '" style="width:' + pct + '%"></div></div>';
            bodyHtml += '<span class="jb-score-dim-val">' + val + '</span>';
            bodyHtml += '</div>';
          });
        });

        if (bd.bonuses && bd.bonuses.length > 0) {
          bodyHtml += '<div class="jb-score-modifiers"><span class="jb-mod-label jb-mod-bonus">Bonuses:</span> ' + bd.bonuses.map(function(b) { return '<span class="jb-mod-tag jb-mod-tag--bonus">' + escapeHtml(b) + '</span>'; }).join(' ') + '</div>';
        }
        if (bd.penalties && bd.penalties.length > 0) {
          bodyHtml += '<div class="jb-score-modifiers"><span class="jb-mod-label jb-mod-penalty">Penalties:</span> ' + bd.penalties.map(function(p) { return '<span class="jb-mod-tag jb-mod-tag--penalty">' + escapeHtml(p) + '</span>'; }).join(' ') + '</div>';
        }

        bodyHtml += '</div></div></div>';
      }

      // ---- 6. Key Matches (collapsible, closed by default) ----
      if (job.keyMatchesParsed && job.keyMatchesParsed.length > 0) {
        bodyHtml += '<div class="cy-detail-section jb-collapsible">';
        bodyHtml += '<div class="jb-collapsible-header" onclick="toggleCollapsible(this)">';
        bodyHtml += '<span class="cy-detail-section-title">Key Matches</span>';
        bodyHtml += '<svg class="jb-collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>';
        bodyHtml += '</div>';
        bodyHtml += '<div class="jb-collapsible-body" style="display: none;">';
        bodyHtml += '<div class="cy-tags">';
        job.keyMatchesParsed.forEach(function(match) {
          bodyHtml += '<span class="cy-tag">' + escapeHtml(match) + '</span>';
        });
        bodyHtml += '</div></div></div>';
      }

      // ---- 7. Summary (collapsible, closed by default) ----
      bodyHtml += '<div class="cy-detail-section jb-collapsible">';
      bodyHtml += '<div class="jb-collapsible-header" onclick="toggleCollapsible(this)">';
      bodyHtml += '<span class="cy-detail-section-title">Summary</span>';
      bodyHtml += '<svg class="jb-collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>';
      bodyHtml += '</div>';
      bodyHtml += '<div class="jb-collapsible-body" style="display: none;">';
      bodyHtml += '<div class="cy-kv-grid">';
      bodyHtml += '<span class="cy-kv-label">Status</span><span class="cy-kv-value"><span class="cy-status ' + job.status + '">' + job.status + '</span></span>';
      bodyHtml += '<span class="cy-kv-label">Company</span><span class="cy-kv-value">' + escapeHtml(job.company) + '</span>';
      bodyHtml += '<span class="cy-kv-label">Location</span><span class="cy-kv-value">' + escapeHtml(job.location || '--') + '</span>';
      bodyHtml += '<span class="cy-kv-label">Posted</span><span class="cy-kv-value">' + escapeHtml(job.postedDate || '--') + '</span>';
      bodyHtml += '</div></div></div>';

      // ---- 8. AI Match Reason (collapsible, closed by default) ----
      if (job.matchReason) {
        bodyHtml += '<div class="cy-detail-section jb-collapsible">';
        bodyHtml += '<div class="jb-collapsible-header" onclick="toggleCollapsible(this)">';
        bodyHtml += '<span class="cy-detail-section-title">AI Match Reason</span>';
        bodyHtml += '<svg class="jb-collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>';
        bodyHtml += '</div>';
        bodyHtml += '<div class="jb-collapsible-body" style="display: none;">';
        bodyHtml += '<p>' + escapeHtml(job.matchReason) + '</p>';
        bodyHtml += '</div></div>';
      }

      // ---- 9. Job Detail chips (collapsible, closed by default) ----
      if (job.seniorityLevel || job.employmentType || job.jobFunction || job.applicantCount) {
        bodyHtml += '<div class="cy-detail-section jb-collapsible">';
        bodyHtml += '<div class="jb-collapsible-header" onclick="toggleCollapsible(this)">';
        bodyHtml += '<span class="cy-detail-section-title">Job Details</span>';
        bodyHtml += '<svg class="jb-collapsible-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>';
        bodyHtml += '</div>';
        bodyHtml += '<div class="jb-collapsible-body" style="display: none;">';
        bodyHtml += '<div class="cy-detail-chips">';
        if (job.seniorityLevel) bodyHtml += '<span class="cy-detail-chip">' + escapeHtml(job.seniorityLevel) + '</span>';
        if (job.employmentType) bodyHtml += '<span class="cy-detail-chip">' + escapeHtml(job.employmentType) + '</span>';
        if (job.jobFunction) bodyHtml += '<span class="cy-detail-chip">' + escapeHtml(job.jobFunction) + '</span>';
        if (job.applicantCount) bodyHtml += '<span class="cy-detail-chip">' + escapeHtml(String(job.applicantCount)) + '</span>';
        bodyHtml += '</div></div></div>';
      }

      document.getElementById('jb-detail-body').innerHTML = bodyHtml;

      // Reset to Info tab and preload chat history
      switchDetailTab('info');
      loadChatHistory(id);

      // Scroll detail body to top
      document.getElementById('jb-detail-body').scrollTop = 0;
    }

    /**
     * Deselect job (used on mobile to go back to list)
     */
    function deselectJob() {
      selectedJobId = null;
      document.getElementById('jb-detail-panel').classList.remove('jb-detail-panel--active');
      document.getElementById('jb-detail-empty').style.display = '';
      document.getElementById('jb-detail-content').style.display = 'none';
      document.getElementById('jb-chat-messages').innerHTML = '';
      switchDetailTab('info');
      var cards = document.querySelectorAll('.jb-card');
      cards.forEach(function(card) { card.classList.remove('jb-card--active'); });
    }

    // ---- Collapsible toggle ----
    function toggleCollapsible(headerEl) {
      var body = headerEl.nextElementSibling;
      var chevron = headerEl.querySelector('.jb-collapsible-chevron');
      if (body.style.display === 'none') {
        body.style.display = '';
        chevron.classList.add('jb-collapsible-chevron--open');
      } else {
        body.style.display = 'none';
        chevron.classList.remove('jb-collapsible-chevron--open');
      }
    }

    // ---- Tab switching ----
    function switchDetailTab(tab) {
      var infoTab = document.getElementById('jb-tab-info');
      var chatTab = document.getElementById('jb-tab-chat');
      var body = document.getElementById('jb-detail-body');
      var chat = document.getElementById('jb-chat');

      if (tab === 'chat') {
        body.style.display = 'none';
        chat.style.display = 'flex';
        infoTab.classList.remove('jb-tab--active');
        chatTab.classList.add('jb-tab--active');
        // Focus input and scroll to bottom
        var input = document.getElementById('jb-chat-input');
        if (input) input.focus();
        var msgs = document.getElementById('jb-chat-messages');
        if (msgs) msgs.scrollTop = msgs.scrollHeight;
      } else {
        body.style.display = '';
        chat.style.display = 'none';
        infoTab.classList.add('jb-tab--active');
        chatTab.classList.remove('jb-tab--active');
      }
    }

    // ---- Chat functions ----
    function loadChatHistory(jobId) {
      var messagesEl = document.getElementById('jb-chat-messages');
      messagesEl.innerHTML = '';
      fetch('/api/chat/' + jobId + '/history')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.messages && data.messages.length > 0) {
            data.messages.forEach(function(msg) {
              appendChatBubble(msg.role, msg.content);
            });
          }
        })
        .catch(function() {
          // Silently fail — chat just starts empty
        });
    }

    function sendChatMessage() {
      var input = document.getElementById('jb-chat-input');
      var sendBtn = document.getElementById('jb-chat-send');
      var message = input.value.trim();
      if (!message || !selectedJobId) return;

      // Disable input while waiting
      input.disabled = true;
      sendBtn.disabled = true;

      appendChatBubble('user', message);
      input.value = '';
      input.style.height = 'auto';
      showTypingIndicator();

      fetch('/api/chat/' + selectedJobId, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: message })
      })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          removeTypingIndicator();
          if (data.error) {
            appendChatBubble('error', data.error);
          } else {
            appendChatBubble('assistant', data.reply);
          }
        })
        .catch(function() {
          removeTypingIndicator();
          appendChatBubble('error', 'Failed to send message. Please try again.');
        })
        .finally(function() {
          input.disabled = false;
          sendBtn.disabled = false;
          input.focus();
        });
    }

    function appendChatBubble(role, content) {
      var messagesEl = document.getElementById('jb-chat-messages');
      var bubble = document.createElement('div');
      bubble.className = 'jb-chat-bubble jb-chat-bubble--' + role;
      bubble.textContent = content;
      messagesEl.appendChild(bubble);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function showTypingIndicator() {
      var messagesEl = document.getElementById('jb-chat-messages');
      var typing = document.createElement('div');
      typing.className = 'jb-chat-typing';
      typing.id = 'jb-chat-typing';
      typing.innerHTML = '<div class="jb-chat-typing-dot"></div><div class="jb-chat-typing-dot"></div><div class="jb-chat-typing-dot"></div>';
      messagesEl.appendChild(typing);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function removeTypingIndicator() {
      var el = document.getElementById('jb-chat-typing');
      if (el) el.remove();
    }

    function clearChat() {
      if (!selectedJobId) return;
      fetch('/api/chat/' + selectedJobId, { method: 'DELETE' })
        .then(function() {
          document.getElementById('jb-chat-messages').innerHTML = '';
          document.getElementById('jb-chat-input').focus();
        })
        .catch(function() {});
    }

    function handleChatKeydown(event) {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        sendChatMessage();
      }
    }

    // Auto-resize chat textarea
    document.getElementById('jb-chat-input').addEventListener('input', function() {
      this.style.height = 'auto';
      this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });

    // Keyboard navigation: arrow keys to move through job list, Enter to select
    document.addEventListener('keydown', function(e) {
      if (e.target.tagName === 'TEXTAREA' || e.target.tagName === 'INPUT') return;

      var cards = Array.from(document.querySelectorAll('.jb-card'));
      if (cards.length === 0) return;

      if (e.key === 'ArrowDown' || e.key === 'j') {
        e.preventDefault();
        var currentIdx = cards.findIndex(function(c) { return c.classList.contains('jb-card--active'); });
        var nextIdx = currentIdx < cards.length - 1 ? currentIdx + 1 : 0;
        var nextId = cards[nextIdx].getAttribute('data-job-id');
        selectJob(nextId);
        cards[nextIdx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      } else if (e.key === 'ArrowUp' || e.key === 'k') {
        e.preventDefault();
        var currentIdx = cards.findIndex(function(c) { return c.classList.contains('jb-card--active'); });
        var prevIdx = currentIdx > 0 ? currentIdx - 1 : cards.length - 1;
        var prevId = cards[prevIdx].getAttribute('data-job-id');
        selectJob(prevId);
        cards[prevIdx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      } else if (e.key === 'Escape') {
        deselectJob();
      }
    });

    // Auto-select first job if there are any
    (function() {
      if (allJobs.length > 0) {
        selectJob(allJobs[0].id);
      }
    })();
  </script>
</body>
</html>
