<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Jobs - Job Tracker</title>
</head>
<body>
  <div class="cy-app">
    <%- include('partials/sidebar', { activePage: 'jobs' }) %>

    <main class="cy-main">
      <div class="cy-page">

        <!-- Breadcrumb (CyFocus style) -->
        <div class="cy-breadcrumb">
          <a href="/">Home</a>
          <span class="cy-breadcrumb-sep">></span>
          <span style="color: var(--text-secondary);">Jobs</span>
        </div>

        <!-- Page Header with view toggle and export -->
        <div class="cy-page-header">
          <h1>Jobs</h1>
          <div class="cy-page-header-actions">
            <!-- View Toggle (CyFocus style) -->
            <div class="cy-view-toggle">
              <a href="/jobs?view=list<%= currentFilter !== 'all' ? '&status=' + currentFilter : '' %>" class="cy-view-btn <%= currentView === 'list' ? 'active' : '' %>" title="List view">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
              </a>
              <a href="/jobs?view=kanban<%= currentFilter !== 'all' ? '&status=' + currentFilter : '' %>" class="cy-view-btn <%= currentView === 'kanban' ? 'active' : '' %>" title="Board view">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="6" height="18" rx="1"/><rect x="9" y="3" width="6" height="12" rx="1"/><rect x="15" y="3" width="6" height="15" rx="1"/></svg>
              </a>
            </div>
            <!-- Export button -->
            <button class="cy-export-btn" onclick="window.print()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Export
            </button>
          </div>
        </div>

        <!-- Filter Chips -->
        <div class="cy-filters">
          <a href="/jobs?view=<%= currentView %>" class="cy-chip <%= currentFilter === 'all' ? 'active' : '' %>">All (<%= stats.totalJobs %>)</a>
          <% statuses.forEach(function(status) { %>
            <a href="/jobs?view=<%= currentView %>&status=<%= status %>" class="cy-chip <%= currentFilter === status ? 'active' : '' %>">
              <%= status.charAt(0).toUpperCase() + status.slice(1) %> (<%= stats.statusCounts[status] || 0 %>)
            </a>
          <% }); %>
        </div>

        <% if (currentView === 'kanban') { %>
          <!-- ============================================================
               KANBAN VIEW
               ============================================================ -->
          <% if (jobs.length === 0) { %>
            <div class="cy-empty">
              <p>No jobs found. <% if (currentFilter !== 'all') { %>Try a different filter or <a href="/jobs?view=kanban">view all</a>.<% } else { %>The scraper hasn't found any matching jobs yet.<% } %></p>
            </div>
          <% } else { %>
            <%
              var columns = {
                'new': jobs.filter(function(j) { return j.status === 'new'; }),
                'reviewed': jobs.filter(function(j) { return j.status === 'reviewed'; }),
                'applied': jobs.filter(function(j) { return j.status === 'applied'; }),
                'rejected': jobs.filter(function(j) { return j.status === 'rejected'; })
              };
            %>
            <div class="cy-kanban">
              <% ['new', 'reviewed', 'applied', 'rejected'].forEach(function(colStatus) { %>
                <div class="cy-kanban-col">
                  <div class="cy-kanban-col-header">
                    <span class="cy-kanban-col-title">
                      <span class="cy-kanban-dot <%= colStatus %>"></span>
                      <%= colStatus.charAt(0).toUpperCase() + colStatus.slice(1) %>
                    </span>
                    <span class="cy-kanban-count"><%= columns[colStatus].length %></span>
                  </div>
                  <div class="cy-kanban-body">
                    <% if (columns[colStatus].length === 0) { %>
                      <div style="text-align: center; padding: 24px 8px; color: var(--text-muted); font-size: 12px;">No jobs</div>
                    <% } %>
                    <% columns[colStatus].forEach(function(job) { %>
                      <div class="cy-k-card<%= job.priority === 'urgent' ? ' priority-urgent' : job.priority === 'high' ? ' priority-high' : '' %>" onclick="openJobDetail('<%= job.id %>')">
                        <% if (job.priority) { %>
                          <div><span class="cy-priority <%= job.priority %>"><%= job.priority.toUpperCase() %></span></div>
                        <% } else if (job.enrichmentStatus === 'pending') { %>
                          <div class="cy-enrichment-pending">Analyzing...</div>
                        <% } %>
                        <div class="cy-k-card-title">
                          <a href="<%= job.link %>" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()"><%= job.title %></a>
                        </div>
                        <div class="cy-k-card-company"><%= job.company %><% if (job.location) { %> &middot; <%= job.location %><% } %></div>
                        <div class="cy-k-card-footer">
                          <span class="cy-k-card-date">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            <%= job.postedDate %>
                          </span>
                          <span class="cy-k-card-score <%= job.matchScore >= 85 ? 'excellent' : job.matchScore >= 70 ? 'good' : job.matchScore >= 50 ? 'decent' : job.matchScore > 0 ? 'low' : 'none' %>">
                            <%= job.matchScore %>
                          </span>
                        </div>
                      </div>
                    <% }); %>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } %>

        <% } else { %>
          <!-- ============================================================
               LIST VIEW
               ============================================================ -->
          <% if (jobs.length === 0) { %>
            <div class="cy-empty">
              <p>No jobs found. <% if (currentFilter !== 'all') { %>Try a different filter or <a href="/jobs?view=list">view all</a>.<% } else { %>The scraper hasn't found any matching jobs yet.<% } %></p>
            </div>
          <% } else { %>
            <div class="cy-panel">
              <div class="cy-panel-flush">
                <div class="cy-table-wrap">
                  <table class="cy-table">
                    <thead>
                      <tr>
                        <th>Score</th>
                        <th>Title</th>
                        <th>Company</th>
                        <th>Location</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% jobs.forEach(function(job) { %>
                        <tr>
                          <td>
                            <span class="cy-score <%= job.matchScore >= 85 ? 'excellent' : job.matchScore >= 70 ? 'good' : job.matchScore >= 50 ? 'decent' : job.matchScore > 0 ? 'low' : 'none' %>">
                              <%= job.matchScore %>
                            </span>
                          </td>
                          <td>
                            <% if (job.priority) { %>
                              <span class="cy-priority <%= job.priority %>"><%= job.priority.toUpperCase() %></span>
                            <% } else if (job.enrichmentStatus === 'pending') { %>
                              <span class="cy-enrichment-pending">Analyzing...</span>
                            <% } %>
                            <a href="<%= job.link %>" target="_blank" rel="noopener noreferrer" class="job-link"><%= job.title %></a>
                          </td>
                          <td><%= job.company %></td>
                          <td><%= job.location %></td>
                          <td class="nowrap"><%= job.postedDate %></td>
                          <td><span class="cy-status <%= job.status %>"><%= job.status %></span></td>
                          <td>
                            <div style="display: flex; gap: 4px; align-items: center;">
                              <button class="cy-btn cy-btn-sm cy-btn-outline" onclick="openJobDetail('<%= job.id %>')">Details</button>
                              <a href="<%= job.applyLink %>" target="_blank" rel="noopener noreferrer" class="cy-btn cy-btn-sm cy-btn-accent">Apply</a>
                            </div>
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          <% } %>
        <% } %>

      </div>
    </main>
  </div>

  <!-- ============================================================
       JOB DETAIL SLIDE-OVER PANEL (CyFocus style)
       ============================================================ -->
  <div class="cy-detail-overlay" id="detail-overlay" onclick="closeJobDetail()"></div>
  <div class="cy-detail-panel" id="detail-panel" style="display: none;">
    <div class="cy-detail-header">
      <span class="cy-detail-title" id="detail-title">Loading...</span>
      <button class="cy-detail-close" onclick="closeJobDetail()" aria-label="Close">&times;</button>
    </div>
    <div class="cy-detail-actions" id="detail-actions"></div>
    <div class="cy-detail-body" id="detail-body">
      <div style="text-align: center; padding: 40px; color: var(--text-muted);">Loading job details...</div>
    </div>
    <div class="cy-detail-notes" id="detail-note-form"></div>
  </div>

  <script>
    var allJobs = <%- JSON.stringify(jobs.map(function(job) { return job; })) %>;

    function findJob(id) {
      return allJobs.find(function(j) { return j.id === id; });
    }

    function openJobDetail(id) {
      var job = findJob(id);
      if (!job) return;

      var overlay = document.getElementById('detail-overlay');
      var panel = document.getElementById('detail-panel');
      overlay.classList.add('active');
      panel.style.display = 'flex';

      // Title
      document.getElementById('detail-title').textContent = job.title;

      // Action buttons (CyFocus: primary filled + outline secondary)
      var actionsHtml = '';
      actionsHtml += '<a href="' + job.applyLink + '" target="_blank" rel="noopener noreferrer" class="cy-btn cy-btn-primary">Apply Now</a>';
      actionsHtml += '<a href="' + job.link + '" target="_blank" rel="noopener noreferrer" class="cy-btn cy-btn-outline">View on LinkedIn</a>';

      var statusForm = '<form method="POST" action="/update-status" class="inline-form">';
      statusForm += '<input type="hidden" name="id" value="' + job.id + '">';
      if (job.status !== 'reviewed') statusForm += '<button type="submit" name="status" value="reviewed" class="cy-btn cy-btn-warning cy-btn-sm">Reviewed</button>';
      if (job.status !== 'applied') statusForm += '<button type="submit" name="status" value="applied" class="cy-btn cy-btn-success cy-btn-sm">Applied</button>';
      if (job.status !== 'rejected') statusForm += '<button type="submit" name="status" value="rejected" class="cy-btn cy-btn-danger cy-btn-sm">Reject</button>';
      statusForm += '</form>';
      actionsHtml += statusForm;
      document.getElementById('detail-actions').innerHTML = actionsHtml;

      // Body with CyFocus-style sections
      var bodyHtml = '';

      // SUMMARY section -- uppercase labels, right-aligned values
      bodyHtml += '<div class="cy-detail-section"><div class="cy-detail-section-title">Summary</div>';
      bodyHtml += '<div class="cy-kv-grid">';
      bodyHtml += '<span class="cy-kv-label">Status</span><span class="cy-kv-value"><span class="cy-status ' + job.status + '">' + job.status + '</span></span>';
      bodyHtml += '<span class="cy-kv-label">Company</span><span class="cy-kv-value">' + escapeHtml(job.company) + '</span>';
      bodyHtml += '<span class="cy-kv-label">Location</span><span class="cy-kv-value">' + escapeHtml(job.location || '--') + '</span>';
      bodyHtml += '<span class="cy-kv-label">Posted</span><span class="cy-kv-value">' + escapeHtml(job.postedDate || '--') + '</span>';
      bodyHtml += '<span class="cy-kv-label">Match Score</span><span class="cy-kv-value"><span class="cy-score ' + (job.matchScore >= 85 ? 'excellent' : job.matchScore >= 70 ? 'good' : job.matchScore >= 50 ? 'decent' : job.matchScore > 0 ? 'low' : 'none') + '">' + job.matchScore + '</span></span>';
      if (job.priority) bodyHtml += '<span class="cy-kv-label">Priority</span><span class="cy-kv-value"><span class="cy-priority ' + job.priority + '">' + job.priority.toUpperCase() + '</span></span>';
      bodyHtml += '</div></div>';

      // Orange gradient divider
      bodyHtml += '<hr class="cy-divider">';

      // Enrichment data
      if (job.enrichmentStatus === 'enriched') {
        if (job.priorityReason) {
          bodyHtml += '<div class="cy-detail-section"><div class="cy-detail-section-title">Priority Reason</div>';
          bodyHtml += '<p>' + escapeHtml(job.priorityReason) + '</p></div>';
        }

        if (job.actionItemsParsed && job.actionItemsParsed.length > 0) {
          bodyHtml += '<div class="cy-detail-section"><div class="cy-detail-section-title">Action Items</div>';
          bodyHtml += '<ul class="cy-action-list">';
          job.actionItemsParsed.forEach(function(item) {
            bodyHtml += '<li>' + escapeHtml(item) + '</li>';
          });
          bodyHtml += '</ul></div>';
        }

        if (job.redFlagsParsed && job.redFlagsParsed.length > 0) {
          bodyHtml += '<div class="cy-detail-section"><div class="cy-detail-section-title">Red Flags</div>';
          bodyHtml += '<ul class="cy-flag-list">';
          job.redFlagsParsed.forEach(function(flag) {
            bodyHtml += '<li>' + escapeHtml(flag) + '</li>';
          });
          bodyHtml += '</ul></div>';
        }

        // Contacts
        if ((job.contactPeopleParsed && job.contactPeopleParsed.length > 0) || job.postedBy) {
          bodyHtml += '<div class="cy-detail-section"><div class="cy-detail-section-title">People to Reach Out To</div>';
          if (job.postedBy) {
            bodyHtml += '<div class="cy-contact-person"><strong>Posted by:</strong>&nbsp;';
            if (job.postedByProfile) bodyHtml += '<a href="' + escapeHtml(job.postedByProfile) + '" target="_blank">' + escapeHtml(job.postedBy) + '</a>';
            else bodyHtml += escapeHtml(job.postedBy);
            if (job.postedByTitle) bodyHtml += ' <span class="cy-hint">&mdash; ' + escapeHtml(job.postedByTitle) + '</span>';
            bodyHtml += '</div>';
          }
          if (job.contactPeopleParsed) {
            job.contactPeopleParsed.forEach(function(person) {
              bodyHtml += '<div class="cy-contact-person">';
              if (person.profileUrl) bodyHtml += '<a href="' + escapeHtml(person.profileUrl) + '" target="_blank">' + escapeHtml(person.name) + '</a>';
              else bodyHtml += escapeHtml(person.name);
              if (person.title) bodyHtml += ' <span class="cy-hint">&mdash; ' + escapeHtml(person.title) + '</span>';
              bodyHtml += '</div>';
            });
          }
          bodyHtml += '</div>';
        }

        bodyHtml += '<hr class="cy-divider">';
      }

      // Match reason
      if (job.matchReason) {
        bodyHtml += '<div class="cy-detail-section"><div class="cy-detail-section-title">AI Match Reason</div>';
        bodyHtml += '<p>' + escapeHtml(job.matchReason) + '</p></div>';
      }

      // Key matches as tags (like CyFocus evidence section)
      if (job.keyMatchesParsed && job.keyMatchesParsed.length > 0) {
        bodyHtml += '<div class="cy-detail-section"><div class="cy-detail-section-title">Key Matches</div>';
        bodyHtml += '<div class="cy-tags">';
        job.keyMatchesParsed.forEach(function(match) {
          bodyHtml += '<span class="cy-tag">' + escapeHtml(match) + '</span>';
        });
        bodyHtml += '</div></div>';
      }

      // Company info
      if (job.companyInfo) {
        bodyHtml += '<div class="cy-detail-section"><div class="cy-detail-section-title">About the Company</div>';
        bodyHtml += '<p>' + escapeHtml(job.companyInfo) + '</p></div>';
      }

      // Job detail chips
      if (job.seniorityLevel || job.employmentType || job.jobFunction || job.applicantCount) {
        bodyHtml += '<div class="cy-detail-section"><div class="cy-detail-section-title">Job Details</div>';
        bodyHtml += '<div class="cy-detail-chips">';
        if (job.seniorityLevel) bodyHtml += '<span class="cy-detail-chip">' + escapeHtml(job.seniorityLevel) + '</span>';
        if (job.employmentType) bodyHtml += '<span class="cy-detail-chip">' + escapeHtml(job.employmentType) + '</span>';
        if (job.jobFunction) bodyHtml += '<span class="cy-detail-chip">' + escapeHtml(job.jobFunction) + '</span>';
        if (job.applicantCount) bodyHtml += '<span class="cy-detail-chip">' + escapeHtml(String(job.applicantCount)) + '</span>';
        bodyHtml += '</div></div>';
      }

      // Full description
      if (job.description) {
        bodyHtml += '<div class="cy-detail-section"><div class="cy-detail-section-title">Full Description</div>';
        bodyHtml += '<div class="cy-desc-full">' + escapeHtml(job.description) + '</div></div>';
      }

      document.getElementById('detail-body').innerHTML = bodyHtml;

      // Note form
      var noteHtml = '<form method="POST" action="/add-note" class="cy-note-form">';
      noteHtml += '<input type="hidden" name="id" value="' + job.id + '">';
      noteHtml += '<textarea name="notes" placeholder="Add notes..." rows="2">' + escapeHtml(job.notes || '') + '</textarea>';
      noteHtml += '<button type="submit" class="cy-btn cy-btn-sm cy-btn-accent">Save</button>';
      noteHtml += '</form>';
      document.getElementById('detail-note-form').innerHTML = noteHtml;

      // Prevent body scroll
      document.body.style.overflow = 'hidden';
    }

    function closeJobDetail() {
      document.getElementById('detail-overlay').classList.remove('active');
      document.getElementById('detail-panel').style.display = 'none';
      document.body.style.overflow = '';
    }

    // Close on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeJobDetail();
    });

    function escapeHtml(str) {
      if (!str) return '';
      var div = document.createElement('div');
      div.appendChild(document.createTextNode(String(str)));
      return div.innerHTML;
    }
  </script>
</body>
</html>
